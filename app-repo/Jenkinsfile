pipeline {
    agent any

    environment {
        // =============================================
        // ⚙️  여기만 본인 환경에 맞게 수정하세요
        // =============================================
        ACR_NAME       = "demoAcrParkjh"
        ACR_LOGIN_URL  = "${ACR_NAME}.azurecr.io"
        APP_NAME       = "parkjh-cicd-test"
        GITHUB_CRED_ID = "github-credentials"
        ACR_CRED_ID    = "acr-service-principal"
        GITHUB_REPO    = "asohee123/git-test"
        // =============================================
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
                script {
                    env.GIT_SHORT_SHA = sh(script: "git rev-parse --short HEAD", returnStdout: true).trim()
                    env.FULL_IMAGE    = "${ACR_LOGIN_URL}/${APP_NAME}:${env.GIT_SHORT_SHA}"
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                sh "docker build -t ${env.FULL_IMAGE} ./app-repo"
            }
        }

        stage('Push to ACR') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: ACR_CRED_ID,
                    usernameVariable: 'ACR_USER',
                    passwordVariable: 'ACR_PASS'
                )]) {
                    sh """
                        docker login ${ACR_LOGIN_URL} -u \$ACR_USER -p \$ACR_PASS
                        docker push ${env.FULL_IMAGE}
                        docker logout ${ACR_LOGIN_URL}
                    """
                }
            }
        }

        stage('Update Manifest') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: GITHUB_CRED_ID,
                    usernameVariable: 'GIT_USER',
                    passwordVariable: 'GIT_TOKEN'
                )]) {
                    sh """
                        sed -i "s|${ACR_LOGIN_URL}/${APP_NAME}:.*|${env.FULL_IMAGE}|g" \
                            manifest-repo/deployment.yaml

                        git config user.email "jenkins@ci.local"
                        git config user.name  "Jenkins CI"
                        git remote set-url origin https://\$GIT_USER:\$GIT_TOKEN@github.com/${GITHUB_REPO}.git
                        git add manifest-repo/deployment.yaml
                        git commit -m "ci: update image to ${env.GIT_SHORT_SHA} [skip ci]"
                        git push origin main
                    """
                }
            }
        }
    }

    post {
        success { echo "✅ 완료: ${env.FULL_IMAGE}" }
        failure { echo "❌ 실패" }
        always  { sh "docker rmi ${env.FULL_IMAGE} || true" }
    }
}
