pipeline {
    agent {
        kubernetes {
            yaml """
apiVersion: v1
kind: Pod
spec:
  containers:
  - name: kaniko
    image: gcr.io/kaniko-project/executor:debug
    command: ['sleep', '9999999']
    volumeMounts:
    - name: docker-config
      mountPath: /kaniko/.docker
  - name: git-tools
    image: alpine/git
    command: ['sleep', '9999999']
  volumes:
  - name: docker-config
    secret:
      secretName: acr-docker-secret   # 사전에 kubectl로 생성 필요 (아래 가이드 참고)
"""
        }
    }

    environment {
        ACR_NAME       = "demoAcrParkjh"
        ACR_LOGIN_URL  = "${ACR_NAME}.azurecr.io"
        APP_NAME       = "parkjh-cicd-test"
        GITHUB_CRED_ID = "github-credentials"
        GITHUB_REPO    = "asohee123/git-test"
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
                script {
                    env.GIT_SHORT_SHA = sh(script: "git rev-parse --short HEAD", returnStdout: true).trim()
                    env.FULL_IMAGE    = "${ACR_LOGIN_URL}/${APP_NAME}:${env.GIT_SHORT_SHA}"
                }
            }
        }

        stage('Build & Push (Kaniko)') {
            steps {
                container('kaniko') {
                    sh """
                        /kaniko/executor \
                            --context=dir://${WORKSPACE}/app-repo \
                            --dockerfile=${WORKSPACE}/app-repo/Dockerfile \
                            --destination=${env.FULL_IMAGE}
                    """
                }
            }
        }

        stage('Update Manifest') {
            steps {
                container('git-tools') {
                    withCredentials([usernamePassword(
                        credentialsId: GITHUB_CRED_ID,
                        usernameVariable: 'GIT_USER',
                        passwordVariable: 'GIT_TOKEN'
                    )]) {
                        sh """
                            sed -i "s|${ACR_LOGIN_URL}/${APP_NAME}:.*|${env.FULL_IMAGE}|g" \
                                manifest-repo/deployment.yaml

                            git config user.email "jenkins@ci.local"
                            git config user.name  "Jenkins CI"
                            git remote set-url origin https://\$GIT_USER:\$GIT_TOKEN@github.com/${GITHUB_REPO}.git
                            git add manifest-repo/deployment.yaml
                            git commit -m "ci: update image to ${env.GIT_SHORT_SHA} [skip ci]"
                            git push origin main
                        """
                    }
                }
            }
        }
    }

    post {
        success { echo "✅ 완료: ${env.FULL_IMAGE}" }
        failure { echo "❌ 실패" }
    }
}
